rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── pets ─────────────────────────────────────────────────────────
    // Qualquer autenticado lê.
    // Protetor cria/edita/deleta os seus.
    // Qualquer autenticado pode marcar um pet disponível como adotado
    // (necessário para o fluxo de adoção que faz batch).
    match /pets/{petId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.protetorId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.protetorId == request.auth.uid
        || (resource.data.status == 'disponivel'
            && request.resource.data.status == 'adotado')
      );
      allow delete: if request.auth != null
        && resource.data.protetorId == request.auth.uid;
    }

    // ── adoptions ────────────────────────────────────────────────────
    // Adotante cria pra si próprio; adotante e protetor leem/editam.
    match /adoptions/{adoptionId} {
      allow read: if request.auth != null && (
        resource.data.adotanteId == request.auth.uid
        || resource.data.protetorId == request.auth.uid
      );
      allow create: if request.auth != null
        && request.resource.data.adotanteId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.adotanteId == request.auth.uid
        || resource.data.protetorId == request.auth.uid
      );
    }

    // ── users ────────────────────────────────────────────────────────
    // Qualquer autenticado lê (necessário pra exibir nome do protetor).
    // Só o próprio usuário escreve no seu doc.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
